@page "/account/register"
@using OnlineStore.Web.ViewModels;
@using OnlineStore.Web.Services.Interfaces
@inject IApiService _apiService;
@inject NavigationManager _navigation;

<PageTitle>Register an account</PageTitle>

<form>
  <div class="form-group">
    <label for="firtName">First Name</label>
    <input type="text" class="form-control w-50" id="firstName" placeholder="Please input First Name"
      @bind="Register.FirstName">
  </div>
  <div class="form-group">
    <label for="lastName">Last Name</label>
    <input type="text" class="form-control w-50" id="lastName" placeholder="Please input Last Name"
      @bind="Register.LastName">
  </div>
  <div class="form-group">
    <label for="userName">User Name</label>
    <input type="text" class="form-control w-50" id="userName" placeholder="Please input User Name"
      @bind="Register.UserName">
  </div>
  <div class="form-group">
    <label for="password">Password</label>
    <input type="password" class="form-control w-50" id="password" placeholder="Please input password"
      @bind="Register.Password">
  </div>
  <div class="form-group">
    <label for="email">Email</label>
    <input type="email" class="form-control w-50" id="email" placeholder="Please input main email"
      @bind="Register.Email">
  </div>
  <div class="form-group">
    <label for="dob">Password</label>
    <InputDate class="form-control w-50" Type="InputDateType.DateTimeLocal" id="dob" @bind-Value="@Register.Dob" />
  </div>
  <div class="form-group">
    <label for="address">Address</label>
    <input type="text" class="form-control w-50" id="address" placeholder="Please input the main address"
      @bind="Register.Address">
  </div>
  <div class="form-group">
    <label for="address2">Address2</label>
    <input type="text" class="form-control w-50" id="address2" placeholder="Please input the secondary address (if any)"
      @bind="Register.Address2">
  </div>
  <div class="form-group">
    <label for="city">City</label>
    <input type="text" class="form-control w-50" id="city" placeholder="Please input the city" @bind="Register.City">
  </div>
  <div class="form-group">
    <label for="province">Province</label>
    <input type="text" class="form-control w-50" id="province" placeholder="Please input the province (if any)"
      @bind="Register.Province">
  </div>
  <button type="button" class="btn btn-primary" @onclick="RegisterAnAccount">Submit</button>
</form>

@code {
  private RegisterViewModel Register = new();
  private async Task RegisterAnAccount()
  {
    await _apiService.PostAsync<RegisterViewModel>("/api/account/register", Register);
    _navigation.NavigateTo("/account/login");
  }
}
